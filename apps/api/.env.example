PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://resq:resq@localhost:5433/resq?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-long-random-string-at-least-64-chars-long
JWT_EXPIRES_IN=2h
REFRESH_EXPIRES_IN=14d

# Africa's Talking (sandbox) — leave AFRICAS_TALKING_API_KEY empty to skip SMS/Voice in dev
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_SHORTCODE=
AFRICAS_TALKING_USSD_CODE=*384#
AFRICAS_TALKING_SENDER_ID=ResQ

# OpenRouter (AI) — leave OPENROUTER_API_KEY empty to disable triage/extraction in dev
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_WHISPER_MODEL=openai/whisper-large-v3

# Google Maps (geocoding) — optional, used as a fallback to Nominatim
GOOGLE_MAPS_API_KEY=

# Allowed web origin (CORS)
WEB_ORIGIN=http://localhost:3000

# Public base URL (for AT webhooks via ngrok)
PUBLIC_BASE_URL=http://localhost:4000

# Demo fallback location for USSD incidents that arrive without GPS
# (Port Harcourt centre by default). Pin appears here on dial, then moves
# when AI extracts a location from the live transcript.
DEMO_FALLBACK_LAT=4.8156
DEMO_FALLBACK_LNG=7.0498
DEMO_FALLBACK_JITTER_KM=0.5

# ElevenLabs Conversational AI (voice agent)
# Leave blank in dev to skip signature verification on /voice/transcript.
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_WEBHOOK_SECRET=
