# Ensure pnpm runs pre/post lifecycle scripts (postinstall on @resq/api
# generates the Prisma client). pnpm 10+ defaults can skip these for
# certain trust modes — making it explicit here so the Render build
# always sees a generated client before tsc runs.
enable-pre-post-scripts=true

# Allow @prisma/client and prisma to run their build scripts during
# install. pnpm 10 sandboxes lifecycle scripts of third-party packages
# by default; Prisma needs to write its query engine binaries.
auto-install-peers=true
